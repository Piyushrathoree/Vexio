{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "es2020",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
